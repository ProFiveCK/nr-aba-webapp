# Server
PORT=4000

# Database (choose DATABASE_URL or discrete params)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aba
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=YOUR_SECURE_DB_PASSWORD
DB_NAME=aba

# Authentication
JWT_SECRET=YOUR_SECURE_JWT_SECRET_MIN_32_CHARS
REVIEWER_SESSION_MINUTES=480
REVIEWER_TEMP_PASSWORD_LENGTH=12
BCRYPT_ROUNDS=12

# Front-end URL for email links and login redirects
FRONTEND_BASE_URL=http://localhost

# Optional default admin bootstrap (clear after first run)
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=change_me_on_first_login
DEFAULT_ADMIN_NAME=Admin User

# SMTP relay (optional but required for notification emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@example.com
SMTP_PASS=YOUR_SMTP_PASSWORD
SMTP_FROM=noreply@example.com

# AI Helper Configuration
AI_HELPER_ENABLED=true
AI_PROVIDER=ollama  # 'ollama' for free local models, or 'openai' for OpenAI
OLLAMA_BASE_URL=http://host.docker.internal:11434  # Ollama API endpoint
OLLAMA_MODEL=llama2  # or llama3, mistral, etc.
# OPENAI_API_KEY=  # Only needed if AI_PROVIDER=openai
