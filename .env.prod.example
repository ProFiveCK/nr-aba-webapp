# ═══════════════════════════════════════════════════════════════
# ABA Stack Environment Configuration Template
# ═══════════════════════════════════════════════════════════════
# 
# This is the ONLY environment file needed for the entire stack.
# Copy this to .env.prod and configure your values.
# 
# Usage:
#   cp .env.prod.example .env.prod
#   nano .env.prod  # Edit with your credentials
#   docker compose up -d
# 
# Or use the interactive setup script:
#   ./setup-dev.sh
# 
# ═══════════════════════════════════════════════════════════════

# Server
PORT=4000

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=YOUR_SECURE_PASSWORD_HERE
POSTGRES_DB=aba
DB_HOST=localhost
# When running via Docker Compose, the API container overrides this to: DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=YOUR_SECURE_PASSWORD_HERE
DB_NAME=aba

# Web Server Port (auto-configured by setup-dev.sh)
# macOS: 8080 (port 80 requires sudo)
# Linux: 80 (production)
WEB_PORT=80

# Authentication
JWT_SECRET=YOUR_SECURE_JWT_SECRET_HERE
REVIEWER_SESSION_MINUTES=480
REVIEWER_TEMP_PASSWORD_LENGTH=12
BCRYPT_ROUNDS=12

# Front-end URL for email links and login redirects
FRONTEND_BASE_URL=https://your-domain.com

# Optional default admin bootstrap (clear after first run)
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=change_me_on_first_login
DEFAULT_ADMIN_NAME=System Admin

# SMTP email settings (optional)
# If unset, email notifications are disabled gracefully.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=notifications@example.com
# SMTP_PASS=change_me
# SMTP_FROM=notifications@example.com
# REPLY_TO_EMAIL=helpdesk@example.com

# ═══════════════════════════════════════════════════════════════
# SFTP Sync Configuration
# ═══════════════════════════════════════════════════════════════
# 
# Choose sync method:
#   - 'database' = Queue sync request in database (default)
#   - 'direct'   = Call Windows sync service immediately
#   - 'file'     = Create trigger file for Windows service to monitor
# 
SFTP_SYNC_METHOD=database
# WINDOWS_SYNC_URL=http://your-windows-server:8088/sync-trigger
SYNC_TIMEOUT=30000

# For file-based sync (optional):
# SYNC_TRIGGER_PATH=/path/to/shared/folder/sync-now.trigger

# AI Helper settings (optional)
# Back-end reads these from environment variables.
AI_HELPER_ENABLED=false
# AI_PROVIDER=ollama
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_MODEL=llama2
# OPENAI_API_KEY=
# GITHUB_TOKEN=
# GITHUB_MODEL=gpt-4o-mini
