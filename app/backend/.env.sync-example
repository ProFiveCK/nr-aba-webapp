# Environment Configuration for SFTP Sync Methods

# Copy this to your backend/.env file and uncomment the method you want to use

# ===== OPTION 1: Database-only (Default - requires waiting for scheduled sync) =====
SFTP_SYNC_METHOD=database

# ===== OPTION 2: Direct Windows Web Service (Immediate sync) =====
# SFTP_SYNC_METHOD=direct
# WINDOWS_SYNC_URL=http://your-windows-server:8088/sync-trigger
# SYNC_TIMEOUT=30000

# ===== OPTION 3: File-based trigger (Immediate sync via file watcher) =====
# SFTP_SYNC_METHOD=file  
# SYNC_TRIGGER_PATH=\\your-windows-server\shared\sync-triggers\sync-now.trigger
# Or for local development:
# SYNC_TRIGGER_PATH=/path/to/shared/folder/sync-now.trigger

# Note: For file-based approach, ensure the web server has write access
# to the specified path, and the Windows server has read access to monitor it.