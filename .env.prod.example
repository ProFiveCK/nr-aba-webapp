# Environment Configuration Template
# Copy this to .env.prod and fill in your actual values

# Server
PORT=4000

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=YOUR_SECURE_PASSWORD_HERE
POSTGRES_DB=aba
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=YOUR_SECURE_PASSWORD_HERE
DB_NAME=aba

# Production Web Port
PROD_WEB_PORT=9000

# Authentication
JWT_SECRET=YOUR_SECURE_JWT_SECRET_HERE
REVIEWER_SESSION_MINUTES=480
REVIEWER_TEMP_PASSWORD_LENGTH=12
BCRYPT_ROUNDS=12

# Front-end URL for email links and login redirects
FRONTEND_BASE_URL=https://your-domain.com

# Optional default admin bootstrap (clear after first run)
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=change_me_on_first_login
DEFAULT_ADMIN_NAME=System Admin

# SMTP relay (optional but required for notification emails)
# IMPORTANT: Use port 587 with STARTTLS (not 465)
SMTP_HOST=your-smtp-server.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=YOUR_SMTP_PASSWORD_HERE
SMTP_FROM=your-email@example.com
REPLY_TO_EMAIL=your-email@example.com

# SFTP Sync Configuration
SFTP_SYNC_METHOD=direct
WINDOWS_SYNC_URL=http://your-windows-server:8088/sync-trigger
SYNC_TIMEOUT=30000
